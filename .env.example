# API Server
PORT=4000
DATABASE_URL=postgresql://perf:perf@localhost:5432/perf_framework
ARTIFACTS_DIR=./artifacts
SCHEDULE_POLL_INTERVAL_MS=30000

# Security — MUST be set in production
# JWT_SECRET=<random-64-char-hex>          # e.g. openssl rand -hex 32
# TOKEN_ENCRYPTION_KEY=<random-64-char-hex> # e.g. openssl rand -hex 32
# JWT_EXPIRES_SECONDS=86400                 # token lifetime (default 24h)

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Worker
API_URL=http://localhost:4000/api/v1
POLL_INTERVAL_MS=5000

# Optional: WebPageTest
# WPT_SERVER=https://your-wpt-instance.com
# WPT_API_KEY=your-key

# Optional: Chrome UX Report
# CRUX_API_KEY=your-google-api-key
